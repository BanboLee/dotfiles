{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "model": "openai/gpt-5.3-codex",
  "provider": {},
  "lsp": {
    "gopls": {
      "disabled": true
    },
    "trae-gopls": {
      "command": ["trae-gopls", "-remote=auto"],
      "extensions": [".go", ".mod", ".sum"]
    }
  },
  "formatter": {
    "goimports-reviser": {
      "command": ["goimports-reviser", "-rm-unused", "-set-alias", "-format"]
    },
    "golines": {
      "command": ["golines", "-m120"]
    }
  },
  "mcp": {
    "web_page_browser": {
      "enabled": true,
      "type": "remote",
      "url": "http://127.0.0.1:12306/mcp",
      "timeout": 20000
    },
    "Context4Code": {
      "enabled": true,
      "type": "remote",
      "timeout": 100000,
      "url": "https://0r2y3xvu.mcp.bytedance.net/sse",
      "headers": {
        "x-code-user-pat": "{env:C4C_user_code}"
      }
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:C7_API_KEY}"
      },
      "enabled": true
    },
    "mri": {
      "type": "local",
      "enabled": true,
      "timeout": 60000,
      "command": [
        "npx",
        "--registry",
        "https://bnpm.byted.org",
        "-y",
        "@byted/mcp-proxy@latest"
      ],
      "environment": {
        "MCP_SERVER_PSM": "bytedance.avinsight.com",
        "MCP_GATEWAY_REGION": "CN"
      }
    },
    "metrics": {
      "type": "local",
      "enabled": false,
      "timeout": 60000,
      "command": [
        "npx",
        "--registry",
        "https://bnpm.byted.org",
        "-y",
        "@byted/mcp-proxy@latest"
      ],
      "environment": {
        "MCP_SERVER_PSM": "bytedance.mcp.metrics",
        "MCP_GATEWAY_REGION": "CN"
      }
    },
    "current_time": {
      "type": "local",
      "enabled": false,
      "timeout": 10000,
      "command": ["uvx", "mcp-server-time"]
    },
    "sequential-thinking": {
      "enabled": false,
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "lark-doc": {
      "enabled": false,
      "type": "remote",
      "url": "{env:LARK_DOC_URL}"
    },
    "codebase": {
      "type": "local",
      "enabled": true,
      "timeout": 60000,
      "command": [
        "go",
        "run",
        "code.byted.org/codebase/mcp-server/cmd/codebase-mcp-server@latest"
      ],
      "environment": {
        "CODE_USER_JWT_TOKEN": "env:CODEBASE_CODE_PAT"
      }
    }
  },
  "plugin": [
    "@mohak34/opencode-notifier@latest",
    "oh-my-openagent@latest",
    "openrtk@latest"
  ]
}
